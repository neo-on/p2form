# ============================================
# Environment Variables Template
# Copy this to .env and fill in your values
# ============================================

# MongoDB Atlas Connection
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/p2formapp?retryWrites=true&w=majority

# Session Secret (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
SESSION_SECRET=CHANGE_ME_TO_A_RANDOM_STRING

# Server Port
PORT=3000

# NSWS API Configuration (UAT)
NSWS_API_URL=https://uat-nsws-mnstrportal.investindia.gov.in/nsws_license/saveP2Data
NSWS_ACCESS_ID=SaveP2Data
NSWS_ACCESS_SECRET=SaveP2Data#0605_NSWS@1252
NSWS_API_KEY=SaveP2Data#0605@AK1161

# Resend Email Configuration (For Forgot Password OTP)
# Uses HTTPS API — works on all VPS providers including Digital Ocean (no SMTP port issues)
# Sign up free at https://resend.com and get your API key from the dashboard
# Free tier: 100 emails/day — uses onboarding@resend.dev as sender (no custom domain needed)
RESEND_API_KEY=
RESEND_FROM="P2 Form Admin <onboarding@resend.dev>"
