<%- include('partials/header') %>

<!-- Navbar -->
<nav class="app-navbar">
  <div class="container-fluid px-4 d-flex align-items-center justify-content-between">
    <a href="/" class="brand">
      <div class="brand-icon"><i class="bi bi-building"></i></div>
      <span>P2 Form</span>
      <span class="pill pill-success">Detail</span>
    </a>
    <div class="nav-actions">
      <a href="/past-requests" class="btn btn-ghost btn-sm" title="All Past Requests"><i class="bi bi-arrow-left"></i><span class="d-none d-md-inline ms-1">Back</span></a>
      <span class="nav-user d-none d-md-flex"><i class="bi bi-person-circle"></i> <%= user.email %></span>
      <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme"></button>
      <a href="/logout" class="btn btn-ghost btn-sm"><i class="bi bi-box-arrow-right"></i></a>
    </div>
  </div>
</nav>

<div class="container py-4" style="max-width: 960px;">

  <!-- Breadcrumb -->
  <nav class="detail-breadcrumb">
    <a href="/past-requests"><i class="bi bi-clock-history"></i> Past Requests</a>
    <i class="bi bi-chevron-right"></i>
    <span><%= submission.month || 'N/A' %> — <%= submission.sugarSeason || 'N/A' %></span>
  </nav>

  <!-- Submission Header Card -->
  <div class="submission-detail-hero">
    <div class="submission-detail-hero-top">
      <div class="submission-detail-icon">
        <i class="bi bi-check-circle-fill"></i>
      </div>
      <div>
        <h3 class="submission-detail-title">
          <%= submission.month || 'N/A' %> — <%= submission.sugarSeason || 'N/A' %>
        </h3>
        <div class="submission-detail-meta">
          <span class="submission-status-badge" style="font-size: 0.8rem;">
            <i class="bi bi-circle-fill" style="font-size:6px"></i> Status <%= submission.statusCode %>
          </span>
          <span class="submission-detail-date">
            <i class="bi bi-calendar3"></i>
            <%= new Date(submission.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric', hour: '2-digit', minute: '2-digit' }) %>
          </span>
          <span class="submission-detail-ref">
            <i class="bi bi-hash"></i> <%= submission._id %>
          </span>
        </div>
      </div>
    </div>
    <div class="submission-detail-hero-actions">
      <a href="/past-requests/<%= submission._id %>/pdf" class="btn btn-accent">
        <i class="bi bi-file-earmark-pdf me-1"></i> Download PDF
      </a>
      <a href="/past-requests" class="btn btn-ghost">
        <i class="bi bi-arrow-left me-1"></i> All Requests
      </a>
    </div>
  </div>

  <!-- Mill Info Bar -->
  <div class="info-bar" style="margin-bottom: 24px;">
    <div class="info-bar-label"><i class="bi bi-shield-check me-1"></i> Mill Details</div>
    <div class="info-bar-grid">
      <div class="info-item"><strong>Undertaking:</strong> <span><%= user.undertakingName %></span></div>
      <div class="info-item"><strong>Plant:</strong> <span><%= user.plantName %> (<%= user.plantCode %>)</span></div>
      <div class="info-item"><strong>State:</strong> <span><%= user.state %></span></div>
      <div class="info-item"><strong>SWS ID:</strong> <span><%= user.swsId %></span></div>
    </div>
  </div>

  <!-- Tab Navigation -->
  <div class="detail-tabs">
    <button class="detail-tab active" data-tab="request" onclick="switchTab('request')">
      <i class="bi bi-send me-1"></i> Request Payload
    </button>
    <button class="detail-tab" data-tab="response" onclick="switchTab('response')">
      <i class="bi bi-reply me-1"></i> API Response
    </button>
    <button class="detail-tab" data-tab="form" onclick="switchTab('form')">
      <i class="bi bi-ui-checks me-1"></i> Form Data
    </button>
  </div>

  <!-- Tab Content: Request Payload -->
  <div class="detail-tab-content active" id="tab-request">
    <div class="json-preview-wrap">
      <div class="json-preview-toolbar">
        <span class="json-preview-label"><i class="bi bi-braces me-1"></i> P2 JSON Payload</span>
        <button class="json-copy-btn" onclick="copyContent('requestJson')" title="Copy to clipboard">
          <i class="bi bi-clipboard"></i>
        </button>
      </div>
      <div class="json-preview">
        <pre id="requestJson"><%= JSON.stringify(submission.p2Json, null, 2) %></pre>
      </div>
    </div>
  </div>

  <!-- Tab Content: API Response -->
  <div class="detail-tab-content" id="tab-response">
    <div class="json-preview-wrap">
      <div class="json-preview-toolbar">
        <span class="json-preview-label"><i class="bi bi-reply-fill me-1"></i> NSWS API Response</span>
        <button class="json-copy-btn" onclick="copyContent('responseJson')" title="Copy to clipboard">
          <i class="bi bi-clipboard"></i>
        </button>
      </div>
      <div class="json-preview">
        <pre id="responseJson"><%= JSON.stringify(submission.apiResponse, null, 2) %></pre>
      </div>
    </div>
  </div>

  <!-- Tab Content: Form Data -->
  <div class="detail-tab-content" id="tab-form">
    <div class="form-data-grid">
      <% const formEntries = Object.entries(submission.formData || {}).filter(([k, v]) => v !== '' && v !== null && v !== undefined && v !== false && v !== 'false' && !k.endsWith('_enabled')); %>
      <% if (formEntries.length === 0) { %>
        <div class="empty-state" style="padding: 40px;">
          <p>No form data available for this submission.</p>
        </div>
      <% } else { %>
        <table class="form-data-table">
          <thead>
            <tr>
              <th>Field</th>
              <th>Value</th>
            </tr>
          </thead>
          <tbody>
            <% formEntries.forEach(([key, value]) => { %>
              <tr>
                <td class="form-data-key"><%= key.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase()) %></td>
                <td class="form-data-value"><%= typeof value === 'object' ? JSON.stringify(value) : value %></td>
              </tr>
            <% }); %>
          </tbody>
        </table>
      <% } %>
    </div>
  </div>

  <!-- Bottom Action Bar -->
  <div class="action-bar" style="margin-top: 32px;">
    <a href="/past-requests" class="btn btn-ghost">
      <i class="bi bi-arrow-left me-1"></i> Back to History
    </a>
    <a href="/past-requests/<%= submission._id %>/pdf" class="btn btn-accent">
      <i class="bi bi-file-earmark-pdf me-1"></i> Download PDF
    </a>
  </div>
</div>

<!-- Toast Notification -->
<div class="toast-container" id="toastContainer"></div>

<script>
// --- Tab Switching ---
function switchTab(tab) {
  document.querySelectorAll('.detail-tab').forEach(function(btn) {
    btn.classList.toggle('active', btn.dataset.tab === tab);
  });
  document.querySelectorAll('.detail-tab-content').forEach(function(el) {
    el.classList.toggle('active', el.id === 'tab-' + tab);
  });
}

// --- Copy to Clipboard ---
function copyContent(elementId) {
  const text = document.getElementById(elementId).textContent;
  navigator.clipboard.writeText(text).then(function() {
    showToast('Copied to clipboard!', 'success');
  });
}

function showToast(message, type) {
  const container = document.getElementById('toastContainer');
  const toast = document.createElement('div');
  toast.className = 'toast-notification toast-' + type;
  const icon = type === 'success' ? 'bi-check-circle-fill' : 'bi-exclamation-circle-fill';
  toast.innerHTML = '<i class="bi ' + icon + ' me-2"></i><span>' + message + '</span>';
  container.appendChild(toast);
  requestAnimationFrame(function() { toast.classList.add('show'); });
  setTimeout(function() {
    toast.classList.remove('show');
    setTimeout(function() { toast.remove(); }, 300);
  }, 3500);
}
</script>
<%- include('partials/footer') %>
