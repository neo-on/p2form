<%- include('partials/header') %>

<!-- Navbar -->
<nav class="app-navbar">
  <div class="container-fluid px-4 d-flex align-items-center justify-content-between">
    <a href="/" class="brand">
      <div class="brand-icon"><i class="bi bi-building"></i></div>
      <span>P2 Form</span>
      <span class="pill pill-<%= success ? 'success' : 'accent' %>"><%= success ? 'Sent' : 'Error' %></span>
    </a>
    <div class="nav-actions">
      <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme"></button>
      <a href="/" class="btn btn-ghost btn-sm"><i class="bi bi-house"></i></a>
    </div>
  </div>
</nav>

<div class="container py-4" style="max-width: 720px;">
  <div class="status-card">
    <% if (success) { %>
      <div class="status-card-header success">
        <div class="status-icon success"><i class="bi bi-check-lg"></i></div>
        <div>
          <h5 class="mb-1" style="color:var(--text-primary); font-weight:700;">Request Successful</h5>
          <span class="status-badge success"><i class="bi bi-circle-fill" style="font-size:6px"></i> Status <%= statusCode %></span>
        </div>
      </div>
    <% } else { %>
      <div class="status-card-header error">
        <div class="status-icon error"><i class="bi bi-x-lg"></i></div>
        <div>
          <h5 class="mb-1" style="color:var(--text-primary); font-weight:700;">Request Failed</h5>
          <span class="status-badge error"><i class="bi bi-circle-fill" style="font-size:6px"></i> Status <%= statusCode %></span>
        </div>
      </div>
    <% } %>

    <div style="padding: 24px;">
      <label class="form-label" style="font-weight:600;">Response</label>
      <div class="json-preview">
        <pre><%= responseData %></pre>
      </div>
    </div>
  </div>

  <div class="d-flex justify-content-between mt-4 mb-4">
    <a href="/" class="btn btn-accent">
      <i class="bi bi-plus-circle me-1"></i> Submit Another Month
    </a>
    <a href="/logout" class="btn btn-ghost">
      <i class="bi bi-box-arrow-right me-1"></i> Logout
    </a>
  </div>
</div>
<%- include('partials/footer') %>
