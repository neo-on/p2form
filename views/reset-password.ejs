<%- include('partials/header') %>
<div class="auth-container">
  <div class="auth-bg">
    <div class="auth-bg-orb"></div>
    <div class="auth-bg-orb"></div>
    <div class="auth-bg-orb"></div>
  </div>
  <div class="auth-card">
    <div class="auth-theme-toggle">
      <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme"></button>
    </div>
    <div class="auth-header">
      <div class="auth-logo"><i class="bi bi-key"></i></div>
      <h2>Reset Password</h2>
      <p>Enter the 6-digit code sent to your email</p>
    </div>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert-modern alert-danger-modern mb-3"><i class="bi bi-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <form method="POST" action="/reset-password">
      <input type="hidden" name="email" value="<%= typeof email !== 'undefined' ? email : '' %>">
      
      <div class="mb-3 text-center">
        <span class="badge" style="background:var(--accent-glare);color:var(--accent-glow);padding:0.5rem 1rem;font-size:0.9rem;border-radius:20px;border:1px solid rgba(var(--accent-raw), 0.3);">
          <i class="bi bi-envelope-check"></i> <%= typeof email !== 'undefined' ? email : '' %>
        </span>
        <div class="mt-2">
          <small class="text-muted" style="opacity: 0.8;"><i class="bi bi-info-circle"></i> Note: The email may take a minute. Please check your Spam or Junk folder.</small>
        </div>
      </div>

      <div class="mb-3">
        <label class="form-label">6-Digit OTP</label>
        <input type="text" name="otp" class="form-control" required autofocus placeholder="123456" maxlength="6" style="letter-spacing:4px; font-weight:bold; text-align:center; font-size:1.2rem;">
      </div>
      <div class="mb-3">
        <label class="form-label">New Password</label>
        <input type="password" name="newPassword" class="form-control" required placeholder="••••••••">
      </div>
      <div class="mb-4">
        <label class="form-label">Confirm New Password</label>
        <input type="password" name="confirmNewPassword" class="form-control" required placeholder="••••••••">
      </div>
      <button type="submit" class="btn btn-accent w-100 mb-3" style="padding: 12px;">
        Update Password <i class="bi bi-check-circle ms-1"></i>
      </button>
    </form>
    <div class="text-center mt-2">
      <a href="/login" class="link-accent">Wait, I remember it. <strong>Log in</strong></a>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
