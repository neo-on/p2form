<%- include('partials/header') %>
<div class="auth-container">
  <div class="auth-bg">
    <div class="auth-bg-orb"></div>
    <div class="auth-bg-orb"></div>
    <div class="auth-bg-orb"></div>
  </div>
  <div class="auth-card" style="text-align: center;">
    <div class="auth-theme-toggle">
      <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme"></button>
    </div>

    <div style="margin-bottom: 24px;">
      <div style="width:72px; height:72px; border-radius:50%; background:var(--warning-soft); display:inline-flex; align-items:center; justify-content:center; margin-bottom:16px;">
        <i class="bi bi-hourglass-split" style="font-size:2rem; color:var(--warning);"></i>
      </div>
      <h2 style="font-weight:700; color:var(--text-primary); margin-bottom:6px;">Pending Approval</h2>
      <p style="color:var(--text-secondary); font-size:0.9rem; margin-bottom:0;">Your account has been registered successfully</p>
    </div>

    <div style="background:var(--bg-tertiary); border-radius:var(--radius-md); padding:20px; margin-bottom:24px; text-align:left;">
      <div style="display:flex; align-items:center; gap:10px; margin-bottom:12px;">
        <i class="bi bi-envelope" style="color:var(--accent); font-size:1.1rem;"></i>
        <span style="color:var(--text-primary); font-weight:500;"><%= email %></span>
      </div>
      <div style="height:1px; background:var(--border-color); margin-bottom:12px;"></div>
      <p style="color:var(--text-secondary); font-size:0.85rem; margin:0; line-height:1.6;">
        <i class="bi bi-info-circle me-1"></i>
        Your account is awaiting admin approval. You will be able to log in once the administrator has approved your access. Please check back later.
      </p>
    </div>

    <div style="display:flex; gap:8px;">
      <a href="/login" class="btn btn-accent" style="flex:1; padding:11px;">
        <i class="bi bi-arrow-left me-1"></i> Back to Login
      </a>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
