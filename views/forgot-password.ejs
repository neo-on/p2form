<%- include('partials/header') %>
<div class="auth-container">
  <div class="auth-bg">
    <div class="auth-bg-orb"></div>
    <div class="auth-bg-orb"></div>
    <div class="auth-bg-orb"></div>
  </div>
  <div class="auth-card">
    <div class="auth-theme-toggle">
      <button class="theme-toggle" onclick="toggleTheme()" aria-label="Toggle theme"></button>
    </div>
    <div class="auth-header">
      <div class="auth-logo"><i class="bi bi-shield-lock"></i></div>
      <h2>Forgot Password</h2>
      <p>Enter your email to receive a 6-digit confirmation code</p>
    </div>
    <% if (typeof error !== 'undefined' && error) { %>
      <div class="alert-modern alert-danger-modern mb-3"><i class="bi bi-exclamation-circle"></i> <%= error %></div>
    <% } %>
    <form method="POST" action="/forgot-password">
      <div class="mb-4">
        <label class="form-label">Email Address</label>
        <input type="email" name="email" class="form-control" required autofocus placeholder="you@sugarmill.com">
      </div>
      <button type="submit" class="btn btn-accent w-100 mb-3" style="padding: 12px;">
        Send OTP Code <i class="bi bi-envelope ms-1"></i>
      </button>
      <div class="text-center mb-2">
        <small class="text-muted" style="opacity: 0.8;"><i class="bi bi-info-circle"></i> Don't forget to check your Spam or Junk folder.</small>
      </div>
    </form>
    <div class="text-center mt-2">
      <a href="/login" class="link-accent"><i class="bi bi-arrow-left me-1"></i>Back to Login</a>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
